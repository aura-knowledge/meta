{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura-knowledge.github.io/meta/schemas/article-proposal.schema.json",
  "title": "Aura Knowledge Article Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "title",
    "thesis",
    "audience",
    "tags",
    "maturity",
    "claims",
    "sources",
    "sanitized_summary",
    "abstraction_examples",
    "privacy_acknowledgment"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "title": { "type": "string", "minLength": 8 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "thesis": { "type": "string", "minLength": 80 },
    "audience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["researchers", "students", "agents", "builders", "policy", "general"]
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "proposed_topic_stem": { "type": "string", "pattern": "^[a-z0-9-/]+$" },
    "other_stem_proposed": { "type": "string", "minLength": 4 },
    "maturity": {
      "type": "string",
      "enum": ["seed", "sprout", "evergreen", "contested"]
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 24 }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url", "type", "accessed"],
        "properties": {
          "title": { "type": "string", "minLength": 4 },
          "url": { "type": "string", "format": "uri" },
          "type": { "type": "string" },
          "accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    },
    "related_articles": {
      "type": "array",
      "items": { "type": "string", "pattern": "^article:[a-z0-9-]+$" }
    },
    "sanitized_summary": { "type": "string", "minLength": 80, "maxLength": 800 },
    "abstraction_examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["original", "abstracted"],
        "properties": {
          "original": { "type": "string", "minLength": 8 },
          "abstracted": { "type": "string", "minLength": 8 }
        }
      }
    },
    "privacy_acknowledgment": { "type": "boolean", "enum": [true] },
    "agent_involvement": { "type": "string", "maxLength": 400 },
    "provenance_bundle": { "$ref": "./provenance-bundle.schema.json" },
    "draft_available": { "type": "boolean" }
  }
}
